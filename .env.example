# Mailjet API Credentials
# Findest du unter: https://app.mailjet.com/account/apikeys
MJ_APIKEY_PUBLIC=dein_public_api_key
MJ_APIKEY_PRIVATE=dein_private_api_key

# Mailjet Contact List ID für das Lead User Panel
# Erstelle eine neue Liste unter: Contacts → Contact Lists → Create
# Die ID findest du in der URL nach dem Erstellen
MJ_LIST_ID=123456

# Server Port (optional, default: 3000)
PORT=3000
